{
  // Custom Claude Code Router - Kevin's Fork
  // ChatGPT Browser Auth + Gemini 3.1 Pro + Agent Routing

  "LOG": true,
  "LOG_LEVEL": "info",
  "API_TIMEOUT_MS": 600000,

  "Providers": [
    // === ChatGPT Plus (Browser Auth - No API Key Needed) ===
    {
      "name": "chatgpt",
      "api_base_url": "https://chatgpt.com/backend-api/conversation",
      "auth_type": "browser",
      "models": ["gpt-4o", "gpt-4o-mini", "o1-pro"],
      "transformer": {
        "use": ["browser-auth", "openai"]
      }
    },

    // === Gemini 3.1 Pro (Google AI API) ===
    {
      "name": "gemini",
      "api_base_url": "https://generativelanguage.googleapis.com/v1beta/models/",
      "api_key": "$GEMINI_API_KEY",
      "models": ["gemini-3.1-pro", "gemini-2.5-pro", "gemini-2.5-flash"],
      "transformer": {
        "use": ["gemini"]
      }
    },

    // === OpenAI API (standard, if you also have API access) ===
    {
      "name": "openai",
      "api_base_url": "https://api.openai.com/v1/chat/completions",
      "api_key": "$OPENAI_API_KEY",
      "models": ["gpt-4o", "gpt-4o-mini"],
      "transformer": {
        "use": []
      }
    },

    // === OpenRouter (fallback, multi-provider) ===
    {
      "name": "openrouter",
      "api_base_url": "https://openrouter.ai/api/v1/chat/completions",
      "api_key": "$OPENROUTER_API_KEY",
      "models": [
        "google/gemini-2.5-pro-preview",
        "anthropic/claude-sonnet-4",
        "deepseek/deepseek-chat"
      ],
      "transformer": {
        "use": ["openrouter"]
      }
    }
  ],

  // === Routing Rules ===
  "Router": {
    "default": "gemini,gemini-3.1-pro",
    "background": "gemini,gemini-2.5-flash",
    "think": "gemini,gemini-3.1-pro",
    "longContext": "gemini,gemini-2.5-pro",
    "longContextThreshold": 60000,
    "webSearch": "gemini,gemini-2.5-flash"
  },

  // === Fallback Models (if primary fails) ===
  "fallback": {
    "default": ["chatgpt,gpt-4o", "openrouter,anthropic/claude-sonnet-4"],
    "think": ["chatgpt,o1-pro", "openrouter,anthropic/claude-sonnet-4"],
    "background": ["chatgpt,gpt-4o-mini"],
    "longContext": ["openrouter,google/gemini-2.5-pro-preview"]
  }
}
